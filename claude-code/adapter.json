{
  "_comment": "Claude Code arrangement. The generator builds, per role: skills/<id>/SKILL.md (frontmatter+body), the bundled shared/ templates, a thin commands/<command>.md wrapper, and (when subagent=true) a thin agents/<id>.md. Authored separately (not generated): .claude-plugin/plugin.json.",
  "kind": "claude-code",
  "roles": {
    "context-librarian": {
      "shared": ["wiki-concept-template.md", "wiki-source-template.md", "wiki-index-template.md", "sources-index-template.md", "wiki-profiles.md", "wiki-registry.example.json"],
      "scripts": ["wikikit.py", "ingest.py"],
      "subagent": true,
      "subagent_tools": "Read, Write, Edit, Glob, Grep, Bash, WebFetch"
    },
    "requirements-analyst": {
      "shared": ["requirements-template.md"],
      "subagent": true,
      "subagent_tools": "Read, Write, Edit, Glob, Grep"
    },
    "story-writer": {
      "shared": ["story-template.md", "definition-of-ready.md", "jira-organization.md", "jira-config.example.json"],
      "subagent": false
    },
    "story-reviewer": {
      "shared": ["definition-of-ready.md"],
      "subagent": false
    },
    "jira-organizer": {
      "shared": ["jira-organization.md", "jira-config.example.json"],
      "subagent": false
    }
  }
}
