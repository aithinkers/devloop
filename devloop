#!/usr/bin/env bash
# devloop — install the DevLoop business-analysis role chain into Claude Code, Kiro, or Codex.
#
#   devloop install   [--host claude|kiro|codex|all] [--scope project|home] [--dry-run]
#   devloop uninstall [--host ...] [--scope ...] [--dry-run]
#   devloop list      [--host ...] [--scope ...]
#   devloop doctor
#   devloop build     [--check]      # (contributors) regenerate platform folders from core/
#   devloop version | help
#
# Scope:  project = current folder (./.claude, ./.kiro, ./.codex)   [default]
#         home    = your user home (~/.claude, ~/.kiro, ~/.codex)
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="$(cat "$REPO/VERSION" 2>/dev/null || echo dev)"
HOSTS_ALL="claude kiro codex"
DRY=0

c()  { printf '\033[%sm%s\033[0m' "$1" "$2"; }      # color
say(){ printf '%s\n' "$*"; }
# Run a command as a real argument vector (never re-parsed by a shell), so paths with spaces,
# quotes, or other metacharacters are safe. Dry-run prints a shell-quoted preview.
run(){ if [ "$DRY" = 1 ]; then printf '  [dry-run]'; printf ' %q' "$@"; printf '\n'; else "$@"; fi; }

# ---- scope → destination roots -------------------------------------------------
claude_dir(){ [ "$1" = home ] && echo "$HOME/.claude" || echo "$PWD/.claude"; }
kiro_dir(){   [ "$1" = home ] && echo "$HOME/.kiro"   || echo "$PWD/.kiro"; }
# Codex Agent Skills live under .agents/skills (home: $HOME, project: $PWD); helper tools and
# config.toml live in $CODEX_HOME (defaults to ~/.codex). AGENTS.md is the chain orchestrator.
codex_home(){ echo "${CODEX_HOME:-$HOME/.codex}"; }
codex_skills_dir(){ [ "$1" = home ] && echo "$HOME/.agents/skills" || echo "$PWD/.agents/skills"; }

# ---- per-host install ----------------------------------------------------------
install_claude(){ local scope="$1" d; d="$(claude_dir "$scope")"
  say "$(c '1;36' "Claude Code") → $d  (skills, commands, agents, tools)"
  run mkdir -p "$d/skills" "$d/commands" "$d/agents" "$d/tools"
  run cp -R "$REPO/skills/."   "$d/skills/"
  run cp -R "$REPO/commands/." "$d/commands/"
  run cp -R "$REPO/agents/."   "$d/agents/"
  run cp    "$REPO"/tools/*.py "$d/tools/"
  run chmod +x "$d"/tools/*.py
}
install_kiro(){ local scope="$1" d; d="$(kiro_dir "$scope")"
  say "$(c '1;36' "Kiro") → $d  (skills, agents, steering, hooks, tools, MCP example)"
  run mkdir -p "$d/skills" "$d/agents" "$d/steering" "$d/hooks" "$d/tools"
  run cp -R "$REPO/skills/."          "$d/skills/"
  run cp "$REPO"/kiro/agents/*.md     "$d/agents/"
  run cp "$REPO"/kiro/steering/*.md   "$d/steering/"
  run cp "$REPO"/kiro/hooks/*.kiro.hook "$d/hooks/"
  run cp "$REPO"/tools/*.py           "$d/tools/"
  run chmod +x "$d"/tools/*.py
  # Hooks/steering reference `.kiro/tools/…` — correct for a project install (Kiro runs hook
  # commands from the workspace root). For a HOME install those must be the absolute ~/.kiro/tools
  # path (shell-quoted, since $HOME may contain spaces), or they break from any other workspace.
  if [ "$scope" = home ]; then
    if [ "$DRY" = 1 ]; then say "  [dry-run] rewrite .kiro/tools → $d/tools (shell-quoted) in installed hooks + steering";
    else for f in "$d/hooks/"*.kiro.hook "$d/steering/devloop.md"; do
      [ -f "$f" ] && python3 -c "
import sys, re, json, shlex
p, td = sys.argv[1], sys.argv[2]
sub = lambda s: re.sub(r'\.kiro/tools/(\S+?\.py)', lambda m: shlex.quote(td + '/' + m.group(1)), s)
if p.endswith('.kiro.hook'):
    d = json.load(open(p)); d['then']['command'] = sub(d['then']['command'])
    out = json.dumps(d, indent=2) + '\n'
else:
    out = sub(open(p).read())
open(p, 'w').write(out)
" "$f" "$d/tools"
    done; fi
  fi
  # MCP config is user-owned: only seed our disabled example if none exists (never clobber).
  if [ -f "$d/settings/mcp.json" ]; then
    say "  note: $d/settings/mcp.json exists — see $REPO/kiro/settings/mcp.json for the SharePoint MCP example."
  else
    run mkdir -p "$d/settings"
    run cp "$REPO/kiro/settings/mcp.json" "$d/settings/"
  fi
}
install_codex(){ local scope="$1" h sk agents_dest; h="$(codex_home)"; sk="$(codex_skills_dir "$scope")"
  say "$(c '1;36' "Codex") → $sk  (Agent Skills) + $h/tools"
  run mkdir -p "$sk" "$h/tools"
  run cp -R "$REPO/skills/." "$sk/"
  run cp "$REPO"/tools/*.py "$h/tools/"
  run chmod +x "$h"/tools/*.py
  # AGENTS.md orchestrator (user-owned): home → $CODEX_HOME, project → $PWD; only if absent.
  [ "$scope" = home ] && agents_dest="$h/AGENTS.md" || agents_dest="$PWD/AGENTS.md"
  if [ -e "$agents_dest" ]; then
    say "  note: $agents_dest exists — review $REPO/codex/AGENTS.md and merge."
  else
    run cp "$REPO/codex/AGENTS.md" "$agents_dest"
  fi
}

# ---- per-host uninstall (only our files) --------------------------------------
uninstall_claude(){ local d; d="$(claude_dir "$1")"
  say "$(c '1;36' Claude) ✗ $d"
  for s in "$REPO"/skills/*/; do run rm -rf "$d/skills/$(basename "$s")"; done
  for f in "$REPO"/commands/*.md; do run rm -f "$d/commands/$(basename "$f")"; done
  for f in "$REPO"/agents/*.md;   do run rm -f "$d/agents/$(basename "$f")"; done
  for f in "$REPO"/tools/*.py; do run rm -f "$d/tools/$(basename "$f")"; done
}
uninstall_kiro(){ local d; d="$(kiro_dir "$1")"
  say "$(c '1;36' Kiro) ✗ $d"
  for s in "$REPO"/skills/*/;           do run rm -rf "$d/skills/$(basename "$s")"; done
  for f in "$REPO"/kiro/agents/*.md;    do run rm -f "$d/agents/$(basename "$f")"; done
  for f in "$REPO"/kiro/steering/*.md;  do run rm -f "$d/steering/$(basename "$f")"; done
  for f in "$REPO"/kiro/hooks/*.kiro.hook; do run rm -f "$d/hooks/$(basename "$f")"; done
  for f in "$REPO"/tools/*.py;          do run rm -f "$d/tools/$(basename "$f")"; done
}
uninstall_codex(){ local scope="$1" h sk; h="$(codex_home)"; sk="$(codex_skills_dir "$scope")"
  say "$(c '1;36' Codex) ✗ $sk"
  for s in "$REPO"/skills/*/; do run rm -rf "$sk/$(basename "$s")"; done
  for f in "$REPO"/tools/*.py; do run rm -f "$h/tools/$(basename "$f")"; done
  # legacy deprecated prompts from pre-0.10 installs
  run rm -f "$h/prompts/spec-context.md" "$h/prompts/spec-requirements.md" "$h/prompts/spec-stories.md" "$h/prompts/spec-review.md" "$h/prompts/spec-jira.md"
}

# ---- list ----------------------------------------------------------------------
present(){ [ -e "$1" ] && c '1;32' "✓" || c '2' "·"; }
list_host(){ case "$1" in
  claude) local d; d="$(claude_dir "$2")"; say "Claude ($2: $d)";
    for s in "$REPO"/skills/*/; do printf '  %s skill %s\n' "$(present "$d/skills/$(basename "$s")")" "$(basename "$s")"; done
    for f in "$REPO"/commands/*.md; do printf '  %s cmd   /%s\n' "$(present "$d/commands/$(basename "$f")")" "$(basename "$f" .md)"; done ;;
  kiro) local d; d="$(kiro_dir "$2")"; say "Kiro ($2: $d)";
    for s in "$REPO"/skills/*/; do printf '  %s skill %s\n' "$(present "$d/skills/$(basename "$s")")" "$(basename "$s")"; done
    for f in "$REPO"/kiro/agents/*.md; do printf '  %s agent %s\n' "$(present "$d/agents/$(basename "$f")")" "$(basename "$f" .md)"; done
    printf '  %s steering #%s\n' "$(present "$d/steering/devloop.md")" "devloop"
    for f in "$REPO"/kiro/hooks/*.kiro.hook; do printf '  %s hook  %s\n' "$(present "$d/hooks/$(basename "$f")")" "$(basename "$f" .kiro.hook)"; done
    printf '  %s settings/mcp.json (MCP example)\n' "$(present "$d/settings/mcp.json")" ;;
  codex) local h sk; h="$(codex_home)"; sk="$(codex_skills_dir "$2")"; say "Codex ($2: skills $sk, tools $h/tools)";
    for s in "$REPO"/skills/*/; do printf '  %s skill %s\n' "$(present "$sk/$(basename "$s")")" "$(basename "$s")"; done ;;
esac; }

# ---- doctor --------------------------------------------------------------------
doctor(){
  say "$(c '1' "devloop $VERSION")  ·  repo: $REPO"
  for t in bash python3 git; do
    if command -v "$t" >/dev/null 2>&1; then say "  $(c '1;32' ✓) $t  $($t --version 2>&1 | head -1)";
    else say "  $(c '1;31' ✗) $t  (required)"; fi
  done
  say ""; say "Build freshness:"
  if python3 "$REPO/build/build.py" --check >/dev/null 2>&1; then say "  $(c '1;32' ✓) generated tree matches core/";
  else say "  $(c '1;31' ✗) generated tree is STALE — run: devloop build"; fi
  say ""; say "Install status (checks real files, not just dirs):"
  for scope in project home; do for h in $HOSTS_ALL; do
    case "$h" in
      claude) d="$(claude_dir "$scope")"; marker="$d/skills/context-librarian/SKILL.md"; wk="$d/tools/wikikit.py";;
      kiro)   d="$(kiro_dir "$scope")";   marker="$d/skills/context-librarian/SKILL.md"; wk="$d/tools/wikikit.py";;
      codex)  marker="$(codex_skills_dir "$scope")/context-librarian/SKILL.md"; wk="$(codex_home)/tools/wikikit.py";;
    esac
    [ -f "$marker" ] || continue   # not installed for this host/scope — stay quiet
    ig="$(dirname "$wk")/ingest.py"
    if [ -f "$wk" ] && python3 -c "import ast,sys; ast.parse(open(sys.argv[1]).read())" "$wk" >/dev/null 2>&1; then
      [ -f "$ig" ] && say "  $(c '1;32' ✓) $h ($scope) — content + helpers (wikikit.py, ingest.py) runnable" \
                   || say "  $(c '1;33' ⚠) $h ($scope) — content present, ingest.py MISSING (reinstall)"
    else
      say "  $(c '1;31' ✗) $h ($scope) — content present but wikikit.py missing/not runnable (reinstall)"
    fi
    # Verify each Kiro hook's command actually resolves to a real script the way a shell parses
    # it (catches workspace-relative leftovers AND unquoted paths with spaces). The base for a
    # relative path is the workspace where Kiro runs hooks (project install → this dir's root).
    if [ "$h" = kiro ]; then
      for hk in "$d/hooks/"*.kiro.hook; do [ -f "$hk" ] || continue
        python3 -c "
import sys, json, shlex, os
hk, base = sys.argv[1], sys.argv[2]
parts = shlex.split(json.load(open(hk))['then']['command'])   # shell-accurate tokenization
pys = [a for a in parts if a.endswith('.py')]
if not pys: sys.exit(0)
sp = pys[0] if os.path.isabs(pys[0]) else os.path.join(base, pys[0])
sys.exit(0 if os.path.isfile(sp) else 1)
" "$hk" "$(dirname "$d")" >/dev/null 2>&1 \
          || say "  $(c '1;33' ⚠) kiro ($scope) — hook $(basename "$hk" .kiro.hook) command path doesn't resolve (reinstall)"
      done
    fi
  done; done
}

# ---- arg parsing ---------------------------------------------------------------
HOST=all; SCOPE=project
parse(){ while [ $# -gt 0 ]; do case "$1" in
  --host) HOST="$2"; shift 2;; --scope) SCOPE="$2"; shift 2;;
  --dry-run) DRY=1; shift;; --check) CHECK=1; shift;;
  *) say "unknown option: $1"; exit 2;; esac; done; }
hosts(){ [ "$HOST" = all ] && echo "$HOSTS_ALL" || echo "$HOST"; }
validate(){ case "$SCOPE" in project|home);; *) say "bad --scope: $SCOPE"; exit 2;; esac
  for h in $(hosts); do case "$h" in claude|kiro|codex);; *) say "bad --host: $h"; exit 2;; esac; done; }

cmd="${1:-help}"; shift || true
case "$cmd" in
  install)   parse "$@"; validate; say "$(c '1' "Installing DevLoop ($SCOPE scope)")"; for h in $(hosts); do install_$h "$SCOPE"; done; say "$(c '1;32' Done.)" ;;
  uninstall) parse "$@"; validate; say "$(c '1' "Uninstalling DevLoop ($SCOPE scope)")"; for h in $(hosts); do uninstall_$h "$SCOPE"; done; say "$(c '1;32' Done.)" ;;
  list)      parse "$@"; validate; for h in $(hosts); do list_host "$h" "$SCOPE"; done ;;
  doctor)    doctor ;;
  build)     CHECK=0; parse "$@"; [ "${CHECK:-0}" = 1 ] && exec python3 "$REPO/build/build.py" --check || exec python3 "$REPO/build/build.py" ;;
  version|--version|-v) say "devloop $VERSION" ;;
  help|--help|-h|*) awk 'NR>1{ if($0 ~ /^#/){ sub(/^# ?/,""); print } else exit }' "$REPO/devloop" ;;
esac
