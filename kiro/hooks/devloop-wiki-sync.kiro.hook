{
  "enabled": true,
  "name": "DevLoop: sync wikis",
  "description": "Clone/pull every git-backed wiki and report which sources changed since the last build (exits non-zero on a git failure). Run manually from the Agent Hooks panel.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python3 tools/wikikit.py sync --all"
  }
}
